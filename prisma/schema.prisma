generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Property {
  id          Int      @id @default(autoincrement())
  name        String
  address     String
  city        String
  zip         String?
  ownership   String   @default("own")
  owner       String?
  totalUnits  Int      @default(0)
  monthlyIncome Float  @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  units       Unit[]
  obligations Obligation[]
  documents   RevisionDoc[]
}

model Unit {
  id          Int      @id @default(autoincrement())
  label       String
  floor       Int?
  size        Float?
  rent        Float    @default(0)
  status      String   @default("vacant")
  tenantName  String?
  tenantEmail String?
  tenantPhone String?
  leaseFrom   DateTime?
  leaseTo     DateTime?
  propertyId  Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  property    Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
}

model Obligation {
  id          Int      @id @default(autoincrement())
  objectName  String
  typeName    String
  deadline    DateTime?
  company     String?
  note        String?
  propertyId  Int?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  property    Property? @relation(fields: [propertyId], references: [id], onDelete: SetNull)
  docs        RevisionDoc[]
}

model RevisionType {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  frequency   String?
  supplier    String?
  createdAt   DateTime @default(now())
}

model RevisionCell {
  id          Int      @id @default(autoincrement())
  objectName  String
  typeName    String
  deadline    DateTime?
  company     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([objectName, typeName])
}

model RevisionDoc {
  id           Int      @id @default(autoincrement())
  title        String
  category     String?
  fileName     String?
  fileUrl      String?
  propertyId   Int?
  obligationId Int?
  createdAt    DateTime @default(now())

  property     Property?   @relation(fields: [propertyId], references: [id], onDelete: SetNull)
  obligation   Obligation? @relation(fields: [obligationId], references: [id], onDelete: SetNull)
}

model Ticket {
  id          Int      @id @default(autoincrement())
  title       String
  description String?
  status      String   @default("open")
  priority    String   @default("normal")
  assignee    String?
  propertyId  Int?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Person {
  id          Int      @id @default(autoincrement())
  name        String
  email       String?
  phone       String?
  role        String   @default("tenant")
  note        String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
